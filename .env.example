PORT=3000
APP_BASE_URL=https://your-public-domain.example.com
APP_SIGNING_SECRET=change-me

SQLITE_DB_PATH=./data/b24-calendar.sqlite

# OAuth keys from Bitrix24 local app form
BITRIX_CLIENT_ID=
BITRIX_CLIENT_SECRET=

# Optional polling window
SYNC_POLL_MIN_MINUTES=10
SYNC_POLL_MAX_MINUTES=15

# Default Yandex CalDAV base URL for new user connections
YANDEX_BASE_URL=https://caldav.yandex.ru
